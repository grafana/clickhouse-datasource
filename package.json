{
  "name": "clickhouse-datasource",
  "version": "4.18.0",
  "description": "Clickhouse Datasource",
  "engines": {
    "node": ">=24",
    "npm": ">=11.6.2"
  },
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "e2e:report": "npx playwright show-report",
    "e2e:ui": "npx playwright test --ui",
    "e2e": "playwright test",
    "gen-dashboards": "node ./gen-db-dashboards",
    "lint:fix": "npm run lint -- --fix && prettier --write --list-different .",
    "lint": "eslint --cache .",
    "prettier:check": "npx prettier --check --ignore-path .prettierignore --list-different=false --log-level=warn \"**/*.{ts,tsx,scss,md,mdx,json,js,cjs}\"",
    "prettier:write": "npx prettier --ignore-path .prettierignore --list-different \"**/*.{js,ts,tsx,scss,md,mdx,json,cjs}\" --write",
    "server": "docker compose up --build",
    "sign": "npx --package=@grafana/sign-plugin@3.2.2 -- sign-plugin",
    "spellcheck": "cspell -c cspell.config.json \"**/*.{ts,tsx,js,go,md,mdx,yml,yaml,json,scss,css}\"",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "test": "jest --watch --onlyChanged",
    "typecheck": "tsc --noEmit"
  },
  "author": "Grafana Labs",
  "license": "Apache-2.0",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@babel/core": "^7.29.0",
    "@grafana/eslint-config": "^8.2.0",
    "@grafana/plugin-e2e": "^3.6.0",
    "@grafana/sign-plugin": "^3.2.2",
    "@grafana/tsconfig": "^2.0.0",
    "@playwright/test": "^1.57.0",
    "@stylistic/eslint-plugin-ts": "^4.4.1",
    "@swc/core": "^1.13.5",
    "@swc/helpers": "^0.5.17",
    "@swc/jest": "^0.2.39",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/glob": "^8.1.0",
    "@types/jest": "^29.5.13",
    "@types/lodash": "^4.17.23",
    "@types/node": "^24.8.0",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@types/webpack-livereload-plugin": "^2.3.6",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "copy-webpack-plugin": "^14.0.0",
    "cspell": "^10.0.0",
    "css-loader": "^7.1.2",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-jsdoc": "^62.8.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-webpack-plugin": "^6.0.0",
    "fork-ts-checker-webpack-plugin": "^9.0.2",
    "glob": "^13.0.3",
    "identity-obj-proxy": "3.0.0",
    "imports-loader": "^5.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.9.0",
    "replace-in-file-webpack-plugin": "^1.0.6",
    "sass": "1.99.0",
    "sass-loader": "16.0.7",
    "style-loader": "4.0.0",
    "swc-loader": "^0.2.6",
    "terser-webpack-plugin": "^5.4.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.9.3",
    "webpack": "^5.105.0",
    "webpack-cli": "^7.0.1",
    "webpack-livereload-plugin": "^3.0.2",
    "webpack-subresource-integrity": "^5.1.0",
    "webpack-virtual-modules": "^0.6.2"
  },
  "overrides": {
    "rxjs": "^7.5.6",
    "picomatch": "4.0.4",
    "brace-expansion@1.x": "1.1.14",
    "brace-expansion@5.x": "5.0.5",
    "minimatch@3.x": "3.1.5",
    "minimatch@10.x": "10.2.5",
    "ajv@8.x": "8.18.0",
    "react-router": "6.30.3",
    "react-router-dom-v5-compat": "6.30.3",
    "@remix-run/router": "1.23.2",
    "immutable": "5.1.5"
  },
  "dependencies": {
    "@emotion/css": "11.13.5",
    "@grafana/data": "12.4.2",
    "@grafana/runtime": "12.4.2",
    "@grafana/schema": "12.4.2",
    "@grafana/ui": "12.4.2",
    "@openfeature/web-sdk": "^1.7.3",
    "pgsql-ast-parser": "^12.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sql-formatter": "^15.6.12",
    "tslib": "2.8.1"
  },
  "packageManager": "npm@11.12.1"
}
