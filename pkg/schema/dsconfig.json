  "instructions": [
    {
      "msg": "Supports no auth (default user), basic auth (username + password), TLS client certificate auth (tlsAuth — mutual TLS with client cert + key, optionally a CA cert), forwarding the signed-in user's Grafana auth/OAuth headers to ClickHouse (forwardGrafanaHeaders / oauthPassThru), and token-based schemes via custom HTTP headers (e.g. a bearer token or API key header, which can be stored securely) — ask which. But never ask for credentials themselves. Those should be entered in the UI",
      "tags": ["llm"]
    }
  ]
