{
  "$schema": "https://raw.githubusercontent.com/grafana/dsconfig/refs/heads/main/dsconfig/schema.json",
  "schemaVersion": "v1",
  "pluginType": "grafana-clickhouse-datasource",
  "pluginName": "ClickHouse",
  "docURL": "https://grafana.com/grafana/plugins/grafana-clickhouse-datasource/",
  "fields": [
    {
      "id": "jsonData.host",
      "key": "host",
      "label": "Server address",
      "description": "ClickHouse host address.",
      "valueType": "string",
      "target": "jsonData",
      "required": true,
      "storage": {
        "type": "computed",
        "read": "jsonData.server"
      },
      "ui": {
        "component": "input",
        "placeholder": "Enter server address"
      }
    },
    {
      "id": "jsonData.port",
      "key": "port",
      "label": "Server port",
      "description": "ClickHouse server port.",
      "valueType": "number",
      "target": "jsonData",
      "required": true,
      "defaultValue": 9000,
      "overrides": [
        {
          "when": "jsonData.protocol == 'native' && jsonData.secure != true",
          "description": "ClickHouse server port (default for Native: 9000).",
          "defaultValue": 9000
        },
        {
          "when": "jsonData.protocol == 'native' && jsonData.secure == true",
          "description": "ClickHouse server port (default for Native (secure): 9440).",
          "defaultValue": 9440
        },
        {
          "when": "jsonData.protocol == 'http' && jsonData.secure != true",
          "description": "ClickHouse server port (default for HTTP: 8123).",
          "defaultValue": 8123
        },
        {
          "when": "jsonData.protocol == 'http' && jsonData.secure == true",
          "description": "ClickHouse server port (default for HTTPS: 8443).",
          "defaultValue": 8443
        }
      ]
    },
    {
      "id": "jsonData.protocol",
      "key": "protocol",
      "label": "Protocol",
      "description": "Native is the default protocol.",
      "valueType": "string",
      "target": "jsonData",
      "required": true,
      "defaultValue": "native",
      "validations": [
        {
          "type": "allowedValues",
          "values": ["native", "http"]
        }
      ],
      "ui": {
        "component": "radio",
        "options": [
          {
            "label": "Native",
            "value": "native"
          },
          {
            "label": "HTTP",
            "value": "http"
          }
        ]
      }
    },
    {
      "id": "jsonData.username",
      "key": "username",
      "label": "Username",
      "description": "We recommend configuring a read-only user.",
      "valueType": "string",
      "target": "jsonData",
      "required": true,
      "ui": {
        "component": "input",
        "placeholder": "Enter username"
      }
    },
    {
      "id": "secureJsonData.password",
      "key": "password",
      "label": "Password",
      "description": "ClickHouse password.",
      "valueType": "string",
      "required": true,
      "role": "auth.basic.password",
      "target": "secureJsonData"
    },
    {
      "id": "jsonData.version",
      "key": "version",
      "label": "Plugin version",
      "description": "Plugin version this config was saved with.",
      "valueType": "string",
      "target": "jsonData"
    },
    {
      "id": "jsonData.secure",
      "key": "secure",
      "label": "Secure Connection",
      "description": "Check to connect securely with TLS.",
      "valueType": "boolean",
      "target": "jsonData",
      "ui": {
        "component": "switch"
      }
    },
    {
      "id": "jsonData.path",
      "key": "path",
      "label": "HTTP URL Path",
      "description": "Additional URL path for HTTP requests. Default: /",
      "valueType": "string",
      "target": "jsonData",
      "dependsOn": "jsonData.protocol == 'http'",
      "ui": {
        "component": "input",
        "placeholder": "additional-path"
      }
    },
    {
      "id": "jsonData.tlsSkipVerify",
      "key": "tlsSkipVerify",
      "label": "Skip TLS Verify",
      "description": "Skip TLS certificate verification.",
      "valueType": "boolean",
      "target": "jsonData",
      "ui": {
        "component": "switch"
      }
    },
    {
      "id": "jsonData.tlsAuth",
      "key": "tlsAuth",
      "label": "TLS Client Auth",
      "description": "Enable TLS client certificate authentication.",
      "valueType": "boolean",
      "target": "jsonData",
      "ui": {
        "component": "switch"
      }
    },
    {
      "id": "jsonData.tlsAuthWithCACert",
      "key": "tlsAuthWithCACert",
      "label": "With CA Cert",
      "description": "Needed for verifying self-signed TLS Certs.",
      "valueType": "boolean",
      "target": "jsonData",
      "ui": {
        "component": "switch"
      }
    },
    {
      "id": "jsonData.defaultDatabase",
      "key": "defaultDatabase",
      "label": "Default database",
      "description": "The default database used by the query builder.",
      "valueType": "string",
      "target": "jsonData",
      "ui": {
        "component": "input",
        "placeholder": "default"
      }
    },
    {
      "id": "jsonData.defaultTable",
      "key": "defaultTable",
      "label": "Default table",
      "description": "The default table used by the query builder.",
      "valueType": "string",
      "target": "jsonData",
      "ui": {
        "component": "input",
        "placeholder": "table"
      }
    },
    {
      "id": "jsonData.connMaxLifetime",
      "key": "connMaxLifetime",
      "label": "Connection Max Lifetime (minutes)",
      "description": "Maximum lifetime of a connection in minutes.",
      "valueType": "string",
      "target": "jsonData",
      "ui": {
        "component": "input",
        "placeholder": "5"
      }
    },
    {
      "id": "jsonData.dialTimeout",
      "key": "dialTimeout",
      "label": "Dial Timeout (seconds)",
      "description": "Timeout in seconds for establishing a connection. Default: 10.",
      "valueType": "string",
      "target": "jsonData",
      "defaultValue": "10",
      "ui": {
        "component": "input",
        "placeholder": "10"
      }
    },
    {
      "id": "jsonData.maxIdleConns",
      "key": "maxIdleConns",
      "label": "Max Idle Connections",
      "description": "Maximum number of idle connections.",
      "valueType": "string",
      "target": "jsonData",
      "ui": {
        "component": "input",
        "placeholder": "25"
      }
    },
    {
      "id": "jsonData.maxOpenConns",
      "key": "maxOpenConns",
      "label": "Max Open Connections",
      "description": "Maximum number of open connections.",
      "valueType": "string",
      "target": "jsonData",
      "ui": {
        "component": "input",
        "placeholder": "50"
      }
    },
    {
      "id": "jsonData.queryTimeout",
      "key": "queryTimeout",
      "label": "Query Timeout (seconds)",
      "description": "Timeout in seconds for read queries. Default: 60.",
      "valueType": "string",
      "target": "jsonData",
      "defaultValue": "60",
      "ui": {
        "component": "input",
        "placeholder": "60"
      }
    },
    {
      "id": "jsonData.validateSql",
      "key": "validateSql",
      "label": "Validate SQL",
      "description": "Validate SQL in the editor.",
      "valueType": "boolean",
      "target": "jsonData",
      "ui": {
        "component": "switch"
      }
    },
    {
      "id": "jsonData.forwardGrafanaHeaders",
      "key": "forwardGrafanaHeaders",
      "label": "Forward Grafana HTTP Headers to data source",
      "description": "Forward Grafana HTTP Headers to data source.",
      "valueType": "boolean",
      "target": "jsonData",
      "dependsOn": "jsonData.protocol == 'http'",
      "ui": {
        "component": "switch"
      }
    },
    {
      "id": "jsonData.enableRowLimit",
      "key": "enableRowLimit",
      "label": "Enable row limit",
      "description": "Enable using the Grafana row limit setting to limit the number of rows returned from ClickHouse. Ensure the appropriate permissions are set for your user. Only supported for Grafana >= 11.0.0. Defaults to false.",
      "valueType": "boolean",
      "target": "jsonData",
      "ui": {
        "component": "switch"
      }
    },
    {
      "id": "secureJsonData.tlsCACert",
      "key": "tlsCACert",
      "label": "CA Cert",
      "description": "PEM-encoded CA certificate.",
      "valueType": "string",
      "target": "secureJsonData",
      "dependsOn": "jsonData.tlsAuthWithCACert == true",
      "ui": {
        "component": "textarea",
        "rows": 7
      }
    },
    {
      "id": "secureJsonData.tlsClientCert",
      "key": "tlsClientCert",
      "label": "Client Cert",
      "description": "PEM-encoded client certificate.",
      "valueType": "string",
      "target": "secureJsonData",
      "dependsOn": "jsonData.tlsAuth == true",
      "ui": {
        "component": "textarea",
        "rows": 7
      }
    },
    {
      "id": "secureJsonData.tlsClientKey",
      "key": "tlsClientKey",
      "label": "Client Key",
      "description": "PEM-encoded client private key.",
      "valueType": "string",
      "role": "tls.clientKey",
      "target": "secureJsonData",
      "dependsOn": "jsonData.tlsAuth == true",
      "ui": {
        "component": "textarea",
        "rows": 7
      }
    },
    {
      "id": "jsonData.logs.defaultDatabase",
      "key": "defaultDatabase",
      "label": "Default log database",
      "description": "The default database used by the logs query builder.",
      "valueType": "string",
      "target": "jsonData",
      "section": "logs",
      "ui": {
        "component": "input",
        "placeholder": "default"
      }
    },
    {
      "id": "jsonData.logs.defaultTable",
      "key": "defaultTable",
      "label": "Default log table",
      "description": "The default table used by the logs query builder.",
      "valueType": "string",
      "target": "jsonData",
      "section": "logs",
      "defaultValue": "otel_logs",
      "ui": {
        "component": "input",
        "placeholder": "otel_logs"
      }
    },
    {
      "id": "jsonData.logs.otelEnabled",
      "key": "otelEnabled",
      "label": "Use OTel",
      "description": "Enable OpenTelemetry schema versioning for log column mappings.",
      "valueType": "boolean",
      "target": "jsonData",
      "section": "logs",
      "ui": {
        "component": "switch"
      }
    },
    {
      "id": "jsonData.logs.otelVersion",
      "key": "otelVersion",
      "label": "OTel version",
      "description": "OpenTelemetry schema version for log columns. Select the version that matches your OTel ClickHouse exporter.",
      "valueType": "string",
      "target": "jsonData",
      "section": "logs",
      "defaultValue": "latest",
      "dependsOn": "jsonData.logs.otelEnabled == true",
      "validations": [
        {
          "type": "allowedValues",
          "values": ["latest", "1.29.0"]
        }
      ],
      "ui": {
        "component": "select",
        "options": [
          {
            "label": "latest (1.2.9)",
            "value": "latest"
          },
          {
            "label": "1.2.9",
            "value": "1.29.0"
          }
        ]
      }
    },
    {
      "id": "jsonData.logs.filterTimeColumn",
      "key": "filterTimeColumn",
      "label": "Filter Time column",
      "description": "Column for time-based partition filtering (lower precision).",
      "valueType": "string",
      "target": "jsonData",
      "section": "logs",
      "defaultValue": "",
      "ui": {
        "component": "input",
        "placeholder": "filter_time_column"
      },
      "overrides": [
        {
          "when": "jsonData.logs.otelEnabled == true",
          "readOnly": true,
          "description": "Set by OTel schema version",
          "defaultValue": "TimestampTime",
          "placeholder": "TimestampTime"
        }
      ]
    },
    {
      "id": "jsonData.logs.timeColumn",
      "key": "timeColumn",
      "label": "Time column",
      "description": "Column for the log timestamp.",
      "valueType": "string",
      "target": "jsonData",
      "section": "logs",
      "defaultValue": "",
      "ui": {
        "component": "input",
        "placeholder": "time_column"
      },
      "overrides": [
        {
          "when": "jsonData.logs.otelEnabled == true",
          "readOnly": true,
          "description": "Set by OTel schema version",
          "defaultValue": "Timestamp",
          "placeholder": "Timestamp"
        }
      ]
    },
    {
      "id": "jsonData.logs.levelColumn",
      "key": "levelColumn",
      "label": "Log Level column",
      "description": "Column for the log level.",
      "valueType": "string",
      "target": "jsonData",
      "section": "logs",
      "defaultValue": "",
      "ui": {
        "component": "input",
        "placeholder": "log_level_column"
      },
      "overrides": [
        {
          "when": "jsonData.logs.otelEnabled == true",
          "readOnly": true,
          "description": "Set by OTel schema version",
          "defaultValue": "SeverityText",
          "placeholder": "SeverityText"
        }
      ]
    },
    {
      "id": "jsonData.logs.messageColumn",
      "key": "messageColumn",
      "label": "Log Message column",
      "description": "Column for the log message body.",
      "valueType": "string",
      "target": "jsonData",
      "section": "logs",
      "defaultValue": "",
      "ui": {
        "component": "input",
        "placeholder": "log_message_column"
      },
      "overrides": [
        {
          "when": "jsonData.logs.otelEnabled == true",
          "readOnly": true,
          "description": "Set by OTel schema version",
          "defaultValue": "Body",
          "placeholder": "Body"
        }
      ]
    },
    {
      "id": "jsonData.logs.showLogLinks",
      "key": "showLogLinks",
      "label": "Show \"View logs\" links",
      "description": "Show \"View logs\" links on trace_id fields for log-to-trace correlation.",
      "valueType": "boolean",
      "target": "jsonData",
      "section": "logs",
      "defaultValue": true,
      "ui": {
        "component": "switch"
      }
    },
    {
      "id": "jsonData.logs.selectContextColumns",
      "key": "selectContextColumns",
      "label": "Auto-Select Columns",
      "description": "When enabled, always include context columns in log queries.",
      "valueType": "boolean",
      "target": "jsonData",
      "section": "logs",
      "defaultValue": true,
      "ui": {
        "component": "switch"
      }
    },
    {
      "id": "jsonData.logs.contextColumns",
      "key": "contextColumns",
      "label": "Context Columns",
      "description": "Column names used for identifying a log's source context.",
      "valueType": "array",
      "target": "jsonData",
      "section": "logs",
      "item": {
        "valueType": "string"
      }
    },
    {
      "id": "jsonData.traces.defaultDatabase",
      "key": "defaultDatabase",
      "label": "Default trace database",
      "description": "The default database used by the trace query builder.",
      "valueType": "string",
      "target": "jsonData",
      "section": "traces",
